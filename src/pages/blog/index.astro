---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await Astro.glob('../../content/posts/*.md')).sort(
  (a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);

const allTags = [...new Set(posts.flatMap((p) => p.frontmatter.tags || []))];
---

<BaseLayout title="博客" description="技术笔记与生活感悟">
  <div class="page-wrap">
    <div class="page-inner">
      <div class="page-header">
        <h1 class="page-title">博客</h1>
        <p class="page-subtitle">共 {posts.length} 篇文章</p>
      </div>

      {allTags.length > 0 && (
        <div class="tags-row">
          {allTags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}

      {posts.length > 0 ? (
        <div class="posts-list">
          {posts.map((post) => {
            const slug = post.file.split('/').pop().replace('.md', '');
            return (
              <PostCard
                title={post.frontmatter.title}
                description={post.frontmatter.description}
                pubDate={post.frontmatter.pubDate}
                slug={slug}
                tags={post.frontmatter.tags}
                categories={post.frontmatter.categories}
              />
            );
          })}
        </div>
      ) : (
        <div class="empty-state">
          <p>还没有文章，敬请期待。</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding: 3rem 0 2rem;
  }

  .page-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
  }

  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .posts-list {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .posts-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .empty-state {
    text-align: center;
    padding: 4rem;
    color: var(--text-muted);
  }
</style>
