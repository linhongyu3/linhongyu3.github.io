---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于" description="关于 lhy">
  <div class="page-wrap">
    <div class="page-inner">
      <div class="page-header">
        <h1 class="page-title">关于</h1>
      </div>

      <div class="about-section">
        <p>你好，欢迎来到我的个人博客。</p>
        <p>这里记录我的技术学习笔记与生活感悟，希望能对有需要的人有所帮助。</p>
      </div>

      <div class="about-section">
        <h2 class="section-title">联系我</h2>
        <div class="contact-list">
          <a href="https://github.com/linhongyu3" target="_blank" rel="noopener noreferrer" class="contact-item">
            GitHub · @linhongyu3
          </a>
          <a href="mailto:linhongyu3@outlook.com" class="contact-item">
            邮箱 · linhongyu3@outlook.com
          </a>
        </div>
      </div>

      <div class="about-section">
        <h2 class="section-title">关于本站</h2>
        <p>本站使用 Astro 构建，部署于 GitHub Pages。</p>
        <p>采用简洁的排版设计，专注于内容本身。</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding: 3rem 0 2rem;
  }

  .page-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .about-section {
    margin-bottom: 2.5rem;
  }

  .about-section p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
  }

  .section-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-item {
    font-size: 0.9rem;
    color: var(--accent);
    text-decoration: none;
  }

  .contact-item:hover {
    text-decoration: underline;
  }
</style>
