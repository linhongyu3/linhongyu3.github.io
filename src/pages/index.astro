---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await Astro.glob('../content/posts/*.md')).sort(
  (a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);

const recentPosts = posts.slice(0, 6);
---

<BaseLayout title="首页" description="lhy 的个人博客，记录技术学习笔记与生活感悟">
  <Hero
    title="你好，我是 lhy"
    subtitle="在这里记录技术学习笔记与生活感悟，慢慢积累，慢慢成长。"
  />

  <section class="page-section">
    <div class="page-inner">
      <div class="section-header">
        <h2 class="section-title">最新文章</h2>
        <a href="/blog/" class="section-more">查看全部</a>
      </div>

      {recentPosts.length > 0 ? (
        <div class="posts-grid">
          {recentPosts.map((post) => {
            const slug = post.file.split('/').pop().replace('.md', '');
            return (
              <PostCard
                title={post.frontmatter.title}
                description={post.frontmatter.description}
                pubDate={post.frontmatter.pubDate}
                slug={slug}
                tags={post.frontmatter.tags}
                categories={post.frontmatter.categories}
              />
            );
          })}
        </div>
      ) : (
        <div class="empty-state">
          <p>还没有文章，敬请期待。</p>
        </div>
      )}
    </div>
  </section>

  <section class="page-section">
    <div class="page-inner">
      <div class="section-header">
        <h2 class="section-title">快速导航</h2>
      </div>
      <div class="nav-grid">
        <a href="/blog/" class="nav-card">
          <div class="nav-card-title">博客</div>
          <div class="nav-card-desc">{posts.length} 篇文章</div>
        </a>
        <a href="/downloads/" class="nav-card">
          <div class="nav-card-title">下载</div>
          <div class="nav-card-desc">工具与软件</div>
        </a>
        <a href="/about/" class="nav-card">
          <div class="nav-card-title">关于</div>
          <div class="nav-card-desc">了解更多</div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-section {
    padding: 2rem 0;
  }

  .page-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .section-more {
    font-size: 0.82rem;
    color: var(--accent);
    text-decoration: none;
  }

  .section-more:hover {
    text-decoration: underline;
  }

  .posts-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
  }

  .nav-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 480px) {
    .nav-grid {
      grid-template-columns: 1fr;
    }
  }

  .nav-card {
    padding: 1.25rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .nav-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow);
  }

  .nav-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .nav-card-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
  }
</style>
