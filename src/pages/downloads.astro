---
import BaseLayout from '../layouts/BaseLayout.astro';
import DownloadCard from '../components/DownloadCard.astro';

const downloadFiles = await Astro.glob('../content/downloads/*.md');

const downloads = downloadFiles.map((file) => ({
  name: file.frontmatter.name,
  description: file.frontmatter.description,
  category: file.frontmatter.category || 'repost',
  download_url: file.frontmatter.download_url,
  size: file.frontmatter.size,
  version: file.frontmatter.version,
  date: file.frontmatter.date,
  group: file.frontmatter.group
}));

const groups = [...new Set(downloads.map((d) => d.group).filter(Boolean))];
const ungrouped = downloads.filter((d) => !d.group);
---

<BaseLayout title="下载" description="工具与软件">
  <div class="page-wrap">
    <div class="page-inner">
      <div class="page-header">
        <h1 class="page-title">下载</h1>
        <p class="page-subtitle">共 {downloads.length} 个项目</p>
      </div>

      <div class="filter-bar">
        <button class="filter-btn active" data-filter="all">全部</button>
        <button class="filter-btn" data-filter="self-made">自制</button>
        <button class="filter-btn" data-filter="repost">转载</button>
      </div>

      {groups.map((groupName) => {
        const groupItems = downloads.filter((d) => d.group === groupName);
        return (
          <div class="dl-group" data-group={groupName}>
            <h2 class="group-title">{groupName}</h2>
            <div class="dl-grid">
              {groupItems.map((item) => (
                <DownloadCard
                  name={item.name}
                  description={item.description}
                  version={item.version}
                  size={item.size}
                  date={item.date}
                  category={item.category}
                  downloadUrl={item.download_url}
                />
              ))}
            </div>
          </div>
        );
      })}

      {ungrouped.length > 0 && (
        <div class="dl-group">
          {groups.length > 0 && <h2 class="group-title">其他</h2>}
          <div class="dl-grid">
            {ungrouped.map((item) => (
              <DownloadCard
                name={item.name}
                description={item.description}
                version={item.version}
                size={item.size}
                date={item.date}
                category={item.category}
                downloadUrl={item.download_url}
              />
            ))}
          </div>
        </div>
      )}

      {downloads.length === 0 && (
        <div class="empty-state">
          <p>暂无内容，敬请期待。</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding: 3rem 0 2rem;
  }

  .page-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .dl-group {
    margin-bottom: 2.5rem;
  }

  .group-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .dl-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .dl-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .empty-state {
    text-align: center;
    padding: 4rem;
    color: var(--text-muted);
  }
</style>

<script is:inline>
  var btns = document.querySelectorAll('.filter-btn');
  var items = document.querySelectorAll('.download-card');
  var groups = document.querySelectorAll('.dl-group');

  btns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var filter = btn.getAttribute('data-filter');
      btns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');

      items.forEach(function(item) {
        var cat = item.getAttribute('data-category') || 'repost';
        var cls = filter === 'all' || cat === filter ? '' : 'none';
        item.style.display = cls;
      });

      groups.forEach(function(g) {
        var visible = g.querySelectorAll('.download-card[style!="display: none"]');
        if (visible.length === 0 && !g.querySelector('.group-title')) {
          var allItems = g.querySelectorAll('.download-card');
          if (allItems.length === 0) g.style.display = 'none';
        }
      });
    });
  });
</script>
