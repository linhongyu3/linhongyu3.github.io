---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="编辑" description="文章和下载项编辑器">
  <div class="admin-wrap">
    <div class="admin-inner">
      <header class="admin-header">
        <h1 class="admin-title">编辑</h1>
        <p class="admin-subtitle">编写文章与下载项，生成 Markdown 文件后放入 <code>src/content/</code> 目录。</p>
      </header>

      <!-- 标签切换 -->
      <div class="tab-bar">
        <button class="tab-btn active" data-tab="posts">文章</button>
        <button class="tab-btn" data-tab="downloads">下载</button>
      </div>

      <!-- 文章管理视图 -->
      <section class="tab-pane active" data-pane="posts">
        <div class="card create-card">
          <h2 class="card-title-sm">新建文章</h2>

          <div class="form-grid">
            <div class="form-item">
              <label class="form-label">标题</label>
              <input type="text" id="post-title" class="form-input" placeholder="请输入标题">
            </div>

            <div class="form-item">
              <label class="form-label">发布日期</label>
              <input type="date" id="post-date" class="form-input">
            </div>

            <div class="form-item form-item-full">
              <label class="form-label">简短描述</label>
              <input type="text" id="post-desc" class="form-input" placeholder="文章摘要，显示在首页卡片中">
            </div>

            <div class="form-item">
              <label class="form-label">分类（英文逗号分隔，可留空）</label>
              <input type="text" id="post-cats" class="form-input" placeholder="例如：技术, 生活">
            </div>

            <div class="form-item">
              <label class="form-label">标签（英文逗号分隔）</label>
              <input type="text" id="post-tags" class="form-input" placeholder="例如：教程, 笔记">
            </div>

            <div class="form-item form-item-full">
              <label class="form-label">正文（Markdown）</label>
              <textarea id="post-body" class="form-textarea" rows="14" placeholder="# 一级标题&#10;&#10;这里是正文..."></textarea>
            </div>
          </div>

          <div class="form-actions">
            <button class="btn-primary" id="btn-post-preview">预览</button>
            <button class="btn-primary" id="btn-post-download">下载 Markdown</button>
            <button class="btn-secondary" id="btn-post-clear">清空</button>
          </div>
        </div>

        <!-- 预览区域 -->
        <div class="card preview-card" id="post-preview-wrap" style="display: none;">
          <h2 class="card-title-sm">文件预览</h2>
          <pre id="post-preview-content" class="preview-pre"></pre>
          <div class="form-actions">
            <button class="btn-primary" id="btn-post-download-2">下载 .md 文件</button>
            <button class="btn-secondary" id="btn-post-copy">复制内容</button>
          </div>
          <p class="help-text">
            下载后请将文件放入 <code>src/content/posts/</code> 目录（文件名建议：2026-06-20-标题.md），然后提交到 GitHub 自动部署。
          </p>
        </div>
      </section>

      <!-- 下载管理视图 -->
      <section class="tab-pane" data-pane="downloads" style="display: none;">
        <div class="card create-card">
          <h2 class="card-title-sm">新建下载项</h2>

          <div class="form-grid">
            <div class="form-item">
              <label class="form-label">名称</label>
              <input type="text" id="dl-name" class="form-input" placeholder="例如：ClassRoomControl">
            </div>

            <div class="form-item">
              <label class="form-label">分类</label>
              <select id="dl-category" class="form-input">
                <option value="self-made">自制</option>
                <option value="repost">转载</option>
              </select>
            </div>

            <div class="form-item form-item-full">
              <label class="form-label">简短描述</label>
              <input type="text" id="dl-desc" class="form-input" placeholder="这是做什么用的">
            </div>

            <div class="form-item">
              <label class="form-label">分组（可留空）</label>
              <input type="text" id="dl-group" class="form-input" placeholder="例如：信息课脱离管控工具">
            </div>
          </div>

          <!-- 版本管理区域 -->
          <div class="versions-section">
            <div class="versions-header">
              <h3 class="versions-title">版本列表</h3>
              <button type="button" class="btn-primary btn-sm" id="btn-add-version">+ 添加版本</button>
            </div>
            <div id="versions-list"></div>
          </div>

          <div class="form-actions">
            <button class="btn-primary" id="btn-dl-preview">预览</button>
            <button class="btn-primary" id="btn-dl-download">下载 Markdown</button>
            <button class="btn-secondary" id="btn-dl-clear">清空</button>
          </div>
        </div>

        <div class="card preview-card" id="dl-preview-wrap" style="display: none;">
          <h2 class="card-title-sm">文件预览</h2>
          <pre id="dl-preview-content" class="preview-pre"></pre>
          <div class="form-actions">
            <button class="btn-primary" id="btn-dl-download-2">下载 .md 文件</button>
            <button class="btn-secondary" id="btn-dl-copy">复制内容</button>
          </div>
          <p class="help-text">
            下载后请将文件放入 <code>src/content/downloads/</code> 目录（文件名：项目名.md），然后提交到 GitHub 自动部署。
          </p>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .admin-wrap {
    padding: 3rem 0 2rem;
  }

  .admin-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
  }

  .admin-header {
    margin-bottom: 2rem;
  }

  .admin-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .admin-subtitle {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0;
  }

  .admin-subtitle code {
    background-color: var(--bg-secondary);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.82em;
    border: 1px solid var(--border);
  }

  .tab-bar {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .tab-btn {
    padding: 0.5rem 1.25rem;
    font-size: 0.88rem;
    background: transparent;
    color: var(--text-muted);
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .tab-btn:hover {
    color: var(--text-primary);
  }

  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    font-weight: 600;
  }

  .card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .card-title-sm {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 1.25rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  .form-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-item-full {
    grid-column: 1 / -1;
  }

  .form-label {
    font-size: 0.82rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .form-input,
  .form-textarea {
    padding: 0.6rem 0.8rem;
    font-size: 0.9rem;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s;
    font-family: inherit;
    outline: none;
    resize: vertical;
    min-width: 0;
  }

  .form-textarea {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--accent);
  }

  .form-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .preview-card {
    padding: 1.5rem;
  }

  .preview-pre {
    background-color: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    font-size: 0.78rem;
    overflow-x: auto;
    color: var(--text-primary);
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    line-height: 1.5;
    white-space: pre;
    max-height: 500px;
    overflow: auto;
  }

  .help-text {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .help-text code {
    background-color: var(--bg-primary);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.82em;
    border: 1px solid var(--border);
  }

  /* 版本管理样式 */
  .versions-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--border);
  }

  .versions-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .versions-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .btn-sm {
    font-size: 0.8rem;
    padding: 0.35rem 0.75rem;
  }

  .version-block {
    background-color: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 0.75rem;
  }

  .version-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .version-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .version-remove {
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.82rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    transition: color 0.2s, background-color 0.2s;
  }

  .version-remove:hover {
    color: #e5484d;
    background-color: rgba(229, 72, 77, 0.1);
  }

  .version-fields {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .version-fields {
      grid-template-columns: 1fr;
    }
  }

  .version-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .version-field-full {
    grid-column: 1 / -1;
  }

  .version-input {
    padding: 0.5rem 0.7rem;
    font-size: 0.85rem;
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: 6px;
    outline: none;
  }

  .version-input:focus {
    border-color: var(--accent);
  }

  /* 架构管理样式 */
  .arch-section {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
  }

  .arch-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .arch-title {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .arch-add {
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
  }

  .arch-row {
    display: grid;
    grid-template-columns: 80px 1fr 100px auto;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 640px) {
    .arch-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .arch-input {
    padding: 0.4rem 0.6rem;
    font-size: 0.8rem;
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: 6px;
    outline: none;
  }

  .arch-input:focus {
    border-color: var(--accent);
  }

  .arch-remove {
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.8rem;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }

  .arch-remove:hover {
    color: #e5484d;
  }
</style>

<script is:inline>
  (function() {
    // Tab 切换
    var tabBtns = document.querySelectorAll('.tab-btn');
    var panes = document.querySelectorAll('.tab-pane');
    tabBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var t = btn.getAttribute('data-tab');
        tabBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        panes.forEach(function(p) {
          p.style.display = p.getAttribute('data-pane') === t ? '' : 'none';
        });
      });
    });

    // 今天的日期
    var today = new Date().toISOString().slice(0, 10);
    var postDate = document.getElementById('post-date');
    if (postDate) postDate.value = today;

    // 版本管理
    var versionsList = document.getElementById('versions-list');
    var versionCounter = 0;

    function createVersionBlock() {
      var idx = ++versionCounter;
      var block = document.createElement('div');
      block.className = 'version-block';
      block.dataset.versionIdx = idx;
      block.innerHTML =
        '<div class="version-header">' +
        '<span class="version-label">版本 #' + idx + '</span>' +
        '<button type="button" class="version-remove">删除版本</button>' +
        '</div>' +
        '<div class="version-fields">' +
        '<div class="version-field"><label class="form-label">版本号</label><input class="version-input v-version" placeholder="v2.0.0"></div>' +
        '<div class="version-field"><label class="form-label">发布日期</label><input class="version-input v-date" type="date" value="' + today + '"></div>' +
        '</div>' +
        '<div class="arch-section">' +
        '<div class="arch-header">' +
        '<span class="arch-title">架构发行版</span>' +
        '<button type="button" class="btn-primary btn-sm arch-add" data-version-idx="' + idx + '">+ 添加架构</button>' +
        '</div>' +
        '<div class="arch-list" data-version-idx="' + idx + '"></div>' +
        '</div>';

      // 删除版本按钮
      block.querySelector('.version-remove').addEventListener('click', function() {
        if (confirm('确定要删除这个版本吗？')) {
          block.remove();
        }
      });

      // 添加架构按钮
      block.querySelector('.arch-add').addEventListener('click', function() {
        createArchRow(block.querySelector('.arch-list'));
      });

      versionsList.appendChild(block);
      // 默认添加一个架构
      createArchRow(block.querySelector('.arch-list'));
      return block;
    }

    function createArchRow(archList) {
      var row = document.createElement('div');
      row.className = 'arch-row';
      row.innerHTML =
        '<input class="arch-input a-arch" placeholder="x64">' +
        '<input class="arch-input a-url" placeholder="下载链接">' +
        '<input class="arch-input a-size" placeholder="大小">' +
        '<button type="button" class="arch-remove">×</button>';

      row.querySelector('.arch-remove').addEventListener('click', function() {
        row.remove();
      });

      archList.appendChild(row);
      return row;
    }

    document.getElementById('btn-add-version').addEventListener('click', createVersionBlock);
    // 默认创建一个版本
    createVersionBlock();

    // 生成文章 Markdown
    function buildPostContent() {
      var title = (document.getElementById('post-title').value || '').trim();
      var date = document.getElementById('post-date').value || today;
      var desc = (document.getElementById('post-desc').value || '').trim();
      var cats = document.getElementById('post-cats').value;
      var tags = document.getElementById('post-tags').value;
      var body = document.getElementById('post-body').value || '';

      var catsArr = cats ? cats.split(/[,，]/).map(function(s) { return s.trim(); }).filter(Boolean) : [];
      var tagsArr = tags ? tags.split(/[,，]/).map(function(s) { return s.trim(); }).filter(Boolean) : [];

      var fm = '---\n';
      fm += 'title: ' + JSON.stringify(title || '未命名文章') + '\n';
      if (desc) fm += 'description: ' + JSON.stringify(desc) + '\n';
      fm += 'pubDate: ' + date + '\n';
      if (catsArr.length) fm += 'categories: [' + catsArr.map(JSON.stringify).join(', ') + ']\n';
      if (tagsArr.length) fm += 'tags: [' + tagsArr.map(JSON.stringify).join(', ') + ']\n';
      fm += '---\n\n';
      return fm + body.replace(/\s+$/, '') + '\n';
    }

    function buildDownloadContent() {
      var name = (document.getElementById('dl-name').value || '').trim();
      var cat = document.getElementById('dl-category').value || 'repost';
      var desc = (document.getElementById('dl-desc').value || '').trim();
      var group = (document.getElementById('dl-group').value || '').trim();

      // 收集版本数据
      var versions = [];
      var versionBlocks = versionsList.querySelectorAll('.version-block');
      versionBlocks.forEach(function(block) {
        var vVersion = block.querySelector('.v-version').value.trim();
        var vDate = block.querySelector('.v-date').value;

        var architectures = [];
        var archRows = block.querySelectorAll('.arch-row');
        archRows.forEach(function(row) {
          var arch = row.querySelector('.a-arch').value.trim();
          var url = row.querySelector('.a-url').value.trim();
          var size = row.querySelector('.a-size').value.trim();
          if (arch || url) {
            architectures.push({ arch: arch, download_url: url, size: size });
          }
        });

        if (vVersion || architectures.length > 0) {
          versions.push({ version: vVersion, date: vDate, architectures: architectures });
        }
      });

      var fm = '---\n';
      fm += 'name: ' + JSON.stringify(name || '未命名') + '\n';
      if (desc) fm += 'description: ' + JSON.stringify(desc) + '\n';
      fm += 'category: ' + cat + '\n';
      if (group) fm += 'group: ' + JSON.stringify(group) + '\n';
      if (versions.length > 0) {
        fm += 'versions:\n';
        versions.forEach(function(v) {
          fm += '  - version: ' + JSON.stringify(v.version || '') + '\n';
          if (v.date) fm += '    date: ' + v.date + '\n';
          if (v.architectures && v.architectures.length > 0) {
            fm += '    architectures:\n';
            v.architectures.forEach(function(a) {
              fm += '      - arch: ' + JSON.stringify(a.arch || '') + '\n';
              if (a.download_url) fm += '        download_url: ' + a.download_url + '\n';
              if (a.size) fm += '        size: ' + a.size + '\n';
            });
          }
        });
      }
      fm += '---\n';
      return fm;
    }

    function download(filename, text) {
      var blob = new Blob([text], { type: 'text/markdown;charset=utf-8' });
      var a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(a.href);
    }

    function copy(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
          alert('已复制到剪贴板');
        }, function() { fallbackCopy(text); });
      } else {
        fallbackCopy(text);
      }
    }

    function fallbackCopy(text) {
      var ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); alert('已复制'); } catch (e) { alert('复制失败，请手动选择复制'); }
      document.body.removeChild(ta);
    }

    // 文章
    document.getElementById('btn-post-preview').addEventListener('click', function() {
      var c = buildPostContent();
      document.getElementById('post-preview-content').textContent = c;
      document.getElementById('post-preview-wrap').style.display = '';
    });

    document.getElementById('btn-post-download').addEventListener('click', function() {
      var c = buildPostContent();
      var title = document.getElementById('post-title').value || '未命名';
      var date = document.getElementById('post-date').value || today;
      download(date + '-' + title.replace(/[\\/:*?"<>|\s]+/g, '-').replace(/^-|-$/g, '') + '.md', c);
    });

    document.getElementById('btn-post-download-2').addEventListener('click', function() {
      document.getElementById('btn-post-download').click();
    });

    document.getElementById('btn-post-copy').addEventListener('click', function() {
      copy(buildPostContent());
    });

    document.getElementById('btn-post-clear').addEventListener('click', function() {
      if (!confirm('确定要清空所有内容吗？')) return;
      ['post-title', 'post-desc', 'post-cats', 'post-tags', 'post-body'].forEach(function(id) {
        document.getElementById(id).value = '';
      });
      document.getElementById('post-preview-wrap').style.display = 'none';
    });

    // 下载项
    document.getElementById('btn-dl-preview').addEventListener('click', function() {
      var c = buildDownloadContent();
      document.getElementById('dl-preview-content').textContent = c;
      document.getElementById('dl-preview-wrap').style.display = '';
    });

    document.getElementById('btn-dl-download').addEventListener('click', function() {
      var c = buildDownloadContent();
      var name = document.getElementById('dl-name').value || '未命名';
      download(name.replace(/[\\/:*?"<>|\s]+/g, '-') + '.md', c);
    });

    document.getElementById('btn-dl-download-2').addEventListener('click', function() {
      document.getElementById('btn-dl-download').click();
    });

    document.getElementById('btn-dl-copy').addEventListener('click', function() {
      copy(buildDownloadContent());
    });

    document.getElementById('btn-dl-clear').addEventListener('click', function() {
      if (!confirm('确定要清空所有内容吗？')) return;
      ['dl-name', 'dl-desc', 'dl-group'].forEach(function(id) {
        document.getElementById(id).value = '';
      });
      versionsList.innerHTML = '';
      versionCounter = 0;
      createVersionBlock();
      document.getElementById('dl-preview-wrap').style.display = 'none';
    });
  })();
</script>