---
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog/', label: '博客' },
  { href: '/downloads/', label: '下载' },
  { href: '/admin/', label: '管理' },
  { href: '/about/', label: '关于' }
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-name">lhy 的笔记</a>

    <nav class="main-nav" aria-label="主导航">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`nav-link ${(pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href))) ? 'active' : ''}`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <button
        id="theme-toggle"
        class="theme-btn"
        aria-label="切换主题"
        title="切换主题"
      >
        <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button id="mobile-menu-btn" class="mobile-menu-btn" aria-label="菜单">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- 移动端菜单 -->
  <div id="mobile-menu" class="mobile-nav" style="display: none;">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`mobile-nav-link ${(pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href))) ? 'active' : ''}`}
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--bg-primary);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .theme-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .theme-btn:hover {
    color: var(--text-primary);
    background-color: var(--bg-secondary);
  }

  .mobile-menu-btn {
    display: none;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    border-radius: 8px;
  }

  .mobile-nav {
    padding: 0.75rem 1.5rem 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background-color: var(--bg-primary);
  }

  .mobile-nav-link {
    padding: 0.6rem 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.15s ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--accent);
    background-color: var(--bg-secondary);
  }

  @media (max-width: 640px) {
    .main-nav { display: none; }
    .mobile-menu-btn { display: flex; }
  }
</style>

<script is:inline>
  (function() {
    var toggleBtn = document.getElementById('theme-toggle');
    var iconSun = document.getElementById('icon-sun');
    var iconMoon = document.getElementById('icon-moon');
    var mobileMenuBtn = document.getElementById('mobile-menu-btn');
    var mobileMenu = document.getElementById('mobile-menu');

    function applyTheme(theme) {
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
        if (iconSun) iconSun.style.display = 'block';
        if (iconMoon) iconMoon.style.display = 'none';
      } else {
        document.documentElement.classList.remove('dark');
        if (iconSun) iconSun.style.display = 'none';
        if (iconMoon) iconMoon.style.display = 'block';
      }
    }

    var saved = localStorage.getItem('theme');
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    applyTheme(saved || (prefersDark ? 'dark' : 'light'));

    toggleBtn && toggleBtn.addEventListener('click', function() {
      var isDark = document.documentElement.classList.contains('dark');
      applyTheme(isDark ? 'light' : 'dark');
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
    });

    mobileMenuBtn && mobileMenuBtn.addEventListener('click', function() {
      var current = mobileMenu && mobileMenu.style.display;
      if (mobileMenu) {
        mobileMenu.style.display = current === 'none' ? 'flex' : 'none';
      }
    });
  })();
</script>
