---
const { title, description, pubDate, slug, tags, categories } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="glass-card rounded-3xl p-6 md:p-8 h-full flex flex-col group cursor-pointer">
  <div class="flex items-start justify-between gap-4 mb-4">
    <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
      <span>📅</span>
      <span>{formattedDate}</span>
    </div>
    {categories && categories.length > 0 && (
      <div class="flex flex-wrap gap-1 justify-end">
        {categories.slice(0, 2).map((cat) => (
          <span class="text-xs px-2 py-1 rounded-lg bg-brand-100 dark:bg-brand-900/30 text-brand-600 dark:text-brand-300">{cat}</span>
        ))}
      </div>
    )}
  </div>

  <h3 class="text-xl font-bold mb-3 text-slate-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
    {title}
  </h3>

  <p class="text-slate-600 dark:text-slate-400 mb-6 flex-grow line-clamp-3">{description}</p>

  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-6">
      {tags.slice(0, 4).map((tag) => (
        <span class="tag-chip">#{tag}</span>
      ))}
    </div>
  )}

  <div class="flex items-center justify-between pt-4 border-t border-slate-200 dark:border-slate-700">
    <span class="text-brand-600 dark:text-brand-400 font-medium">阅读文章</span>
    <span class="text-2xl transform group-hover:translate-x-1 transition-transform">→</span>
  </div>
</article>

<style is:global>
.line-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style>
