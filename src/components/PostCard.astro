---
const { title, description, pubDate, tags, categories } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<a href={`/blog/${Astro.props.slug}/`} class="post-card">
  <h2 class="card-title">{title}</h2>
  {description && <p class="card-desc">{description}</p>}
  <div class="card-meta">
    <span>{formattedDate}</span>
    {categories && categories.length > 0 && (
      <span class="meta-sep">&middot;</span>
    )}
    {categories && categories.slice(0, 1).map((cat) => (
      <span>{cat}</span>
    ))}
  </div>
  {tags && tags.length > 0 && (
    <div class="card-tags" style="margin-top: 0.75rem;">
      {tags.slice(0, 3).map((tag) => (
        <span class="tag">#{tag}</span>
      ))}
    </div>
  )}
</a>

<style>
  .meta-sep {
    margin: 0 0.4rem;
    color: var(--border);
  }
</style>
