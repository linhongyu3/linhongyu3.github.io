---
const { title, subtitle } = Astro.props;
---

<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-title">{title || '你好'}</h1>
    <p class="hero-subtitle">{subtitle || '记录技术学习笔记与生活感悟'}</p>
    <div class="hero-actions">
      <a href="/blog/" class="btn-primary">阅读博客</a>
      <a href="/about/" class="btn-secondary">关于我</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 5rem 0 3rem;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: left;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 1rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin: 0 0 2rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
</style>
