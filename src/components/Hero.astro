---
const { title, subtitle, tagline } = Astro.props;
---

<section class="pt-32 pb-16 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 mb-8 animate-fade-in opacity-0">
      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
      <span class="text-sm text-slate-600 dark:text-slate-300">{tagline || '欢迎来到我的个人空间'}</span>
    </div>

    <h1 class="text-5xl md:text-7xl font-black mb-6 animate-slide-up opacity-0 delay-100">
      <span class="gradient-text">{title || 'Hello, World!'}</span>
    </h1>

    <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed animate-slide-up opacity-0 delay-200">
      {subtitle || '在这里分享技术笔记、编程心得与生活的点点滴滴。'}
    </p>

    <div class="flex flex-wrap justify-center gap-4 animate-slide-up opacity-0 delay-300">
      <a href="/blog/" class="btn-primary">
        📖 阅读博客
      </a>
      <a href="/downloads/" class="btn-secondary">
        ⬇️ 软件下载
      </a>
    </div>
  </div>
</section>

<style is:global>
.animate-fade-in {
  animation: fadeIn 0.8s ease-out forwards;
}
.animate-slide-up {
  animation: slideUp 0.8s ease-out forwards;
}
</style>
