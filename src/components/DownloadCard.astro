---
const { name, description, version, size, date, category, downloadUrl } = Astro.props;

const formattedDate = date
  ? new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const isSelfMade = category === 'self-made';
---

<div class="download-card">
  <div class="dl-header">
    <div>
      <div class="dl-name">{name}</div>
      <span class={`dl-badge download-badge-${isSelfMade ? 'self' : 'repost'}`}>
        {isSelfMade ? '自制' : '转载'}
      </span>
    </div>
  </div>

  {description && <p class="dl-desc">{description}</p>}

  <div class="dl-meta">
    {version && <span>v{version}</span>}
    {version && size && <span class="meta-sep">&middot;</span>}
    {size && <span>{size}</span>}
    {formattedDate && ((version || size) && <span class="meta-sep">&middot;</span>)}
    {formattedDate && <span>{formattedDate}</span>}
  </div>

  <div class="dl-actions">
    <a
      href={downloadUrl}
      class="btn-primary dl-btn"
      data-original-url={downloadUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      下载
    </a>
    <select class="mirror-select" title="选择加速源">
      <option value="">直连</option>
      <option value="https://v6.gh-proxy.org/">gh-proxy v6</option>
      <option value="https://v1.gh-proxy.org/">gh-proxy v1</option>
      <option value="https://ghproxy.com/">ghproxy.com</option>
    </select>
  </div>
</div>

<style>
  .dl-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .dl-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .dl-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .dl-btn {
    font-size: 0.85rem;
    padding: 0.45rem 1rem;
  }

  .mirror-select {
    flex: 1;
    padding: 0.45rem 0.75rem;
    font-size: 0.82rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background-color: var(--bg-primary);
    color: var(--text-secondary);
    cursor: pointer;
    transition: border-color 0.2s;
    outline: none;
    max-width: 160px;
  }

  .mirror-select:focus {
    border-color: var(--accent);
  }

  .meta-sep {
    color: var(--border);
  }
</style>

<script is:inline>
  document.querySelectorAll('.mirror-select').forEach(function(select) {
    select.addEventListener('change', function() {
      var url = this.value;
      var card = this.closest('.download-card');
      var btn = card && card.querySelector('.dl-btn');
      var orig = btn && btn.getAttribute('data-original-url');
      if (orig) {
        btn.href = url ? url + orig : orig;
      }
    });
  });
</script>
