---
const { name, description, version, size, date, category, downloadUrl, mirrors } = Astro.props;

const formattedDate = date ? new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) : null;
const isSelfMade = category === 'self-made';
---

<div class="glass-card rounded-3xl p-6 md:p-8 download-item" data-category={category}>
  <div class="flex items-start justify-between gap-4 mb-4">
    <div class="flex items-center gap-3">
      <div class={`w-14 h-14 rounded-2xl flex items-center justify-center text-2xl font-bold ${isSelfMade ? 'bg-gradient-to-br from-brand-500 to-purple-500 text-white shadow-glow' : 'bg-gradient-to-br from-pink-500 to-rose-500 text-white shadow-lg'}`}>
        {isSelfMade ? '🛠️' : '📦'}
      </div>
      <div>
        <h4 class="text-xl font-bold text-slate-900 dark:text-white">{name}</h4>
        <span class={`text-xs px-2 py-1 rounded-full inline-block mt-1 ${isSelfMade ? 'bg-brand-100 dark:bg-brand-900/40 text-brand-700 dark:text-brand-300' : 'bg-pink-100 dark:bg-pink-900/40 text-pink-700 dark:text-pink-300'}`}>
          {isSelfMade ? '自制' : '转载'}
        </span>
      </div>
    </div>
  </div>

  {description && (
    <p class="text-slate-600 dark:text-slate-400 mb-4">{description}</p>
  )}

  <div class="flex flex-wrap gap-2 mb-6">
    {version && (
      <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-sm bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">
        <span>🔖</span>
        <span>{version}</span>
      </span>
    )}
    {size && (
      <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-sm bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">
        <span>📦</span>
        <span>{size}</span>
      </span>
    )}
    {formattedDate && (
      <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-sm bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">
        <span>📅</span>
        <span>{formattedDate}</span>
      </span>
    )}
  </div>

  <div class="space-y-3">
    <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
      <span>⚡ 加速源：</span>
      <select class="mirror-select flex-1 px-3 py-2 rounded-xl bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 outline-none focus:border-brand-500">
        <option value="">直接下载（不加速）</option>
      </select>
    </div>

    <a
      href={downloadUrl}
      class="download-btn flex items-center justify-center gap-2 w-full px-6 py-3 rounded-xl font-medium text-white bg-gradient-to-r from-brand-500 to-purple-500 hover:shadow-glow hover:-translate-y-0.5 transition-all"
      data-original-url={downloadUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>⬇️</span>
      <span>下载 {name}</span>
    </a>
  </div>
</div>
