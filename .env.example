# ============ Halo 博客环境变量 ============
# 复制此文件为 .env 后修改下面的值

# ---- 数据库（与 docker-compose.yml 中保持一致）----
DB_USERNAME=halo
DB_PASSWORD=please_change_this_to_strong_password

# ---- 管理员账号（首次启动时初始化）----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please_change_this_to_strong_password

# ---- 外部访问地址（生产环境请改为你的域名，如 https://blog.example.com）----
EXTERNAL_URL=http://localhost:8090
